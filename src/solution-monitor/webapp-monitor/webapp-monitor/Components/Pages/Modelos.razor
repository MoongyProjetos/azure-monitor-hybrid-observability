@page "/modelos"
@attribute [StreamRendering]

@using System.Text.Json
@using webapp_monitor.Models
@inject IConfiguration Configuration
@inject ILogger<Modelos> _logger

<PageTitle>Modelos</PageTitle>

<h1>Modelos de Produto</h1>

@if (modelos == null)
{
    <p><em>Carregando...</em></p>
}
else if (!modelos.Any())
{
    <p>Nenhum modelo encontrado.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Descrição</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var modelo in modelos)
            {
                <tr>
                    <td>@modelo.ProductModelId</td>
                    <td>@modelo.Name</td>
                    <td>@modelo.CatalogDescription</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ProductModel>? modelos;

    protected override async Task OnInitializedAsync()
    {
        using var http = new HttpClient();
        var baseUrl = Configuration["ApiSettings:BaseUrl"];
        var endpoint = Configuration["ApiSettings:ObterModelos"];

        var url = $"{baseUrl}{endpoint}";

        // url = "https://func-monitor-brz-jaon.azurewebsites.net/api/ObterModelos";

        var response = await http.GetAsync(url);

        if (response.IsSuccessStatusCode)
        {
            var json = await response.Content.ReadAsStringAsync();

            modelos = JsonSerializer.Deserialize<List<ProductModel>>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        else
        {
            modelos = new List<ProductModel>();
        }

        _logger.LogInformation("Teste Application Insights funcionando 🚀");
    }
}